library GoldenBasicLiterals version '1.0.0'

// Integer and decimal literals
define IntLiteral: 42
define NegIntLiteral: -7
define DecimalLiteral: 3.14

// String literals
define StrLiteral: 'hello world'
define EmptyStr: ''

// Boolean literals
define TrueLiteral: true
define FalseLiteral: false

// Null
define NullLiteral: null
