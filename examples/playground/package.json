{
  "name": "@reasonhealth/playground",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:deps": "pnpm --filter @reasonhealth/fhirpath --filter @reasonhealth/vcl --filter @reasonhealth/cql build",
    "predev": "pnpm run build:deps",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@reasonhealth/cql": "workspace:*",
    "@reasonhealth/fhirpath": "workspace:*",
    "@reasonhealth/vcl": "workspace:*"
  },
  "devDependencies": {
    "vite": "^7.2.6",
    "vitest": "^4.0.14"
  }
}
